generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  streak        Int       @default(0)
  lastActive    DateTime  @default(now())
  
  testResults   TestResult[]
  bookmarks     Bookmark[]
  
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Question {
  id            String   @id @default(cuid())
  content       String
  topic         String   // "Aptitude", "Logical Reasoning", "Verbal Ability", "English", "Scenario-Based", "Coding"
  subTopic      String?  // e.g., "Percentages", "Blood Relations", "Reading comprehension"
  difficulty    String   @default("medium") // "easy", "medium", "hard", "challenge"
  options       String?  // JSON string storing options if MCQ
  correctOption String?  // e.g., "A" or the exact string
  solution      String?  // Detailed explanation
  reliability   String   @default("verified") // "verified", "memory-based", "generated"
  source        String?  // URL or "TCS NQT 2023"
  
  bookmarks     Bookmark[]
}

model TestResult {
  id             String   @id @default(cuid())
  userId         String
  score          Float
  totalQuestions Int
  timeSpent      Int      // in seconds
  sectionScores  String?  // JSON string of section-wise scores
  weakAreas      String?  // JSON array of strings
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
}

model Bookmark {
  id           String   @id @default(cuid())
  userId       String
  questionId   String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
  question     Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}
